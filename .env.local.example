# ── Anthropic / Ask RI ───────────────────────────────────────
# REQUIRED for the Ask RI chatbot to work.
# 1. Go to console.anthropic.com → API Keys → Create Key
# 2. Add it here AND in Vercel: Settings → Environment Variables → ANTHROPIC_API_KEY

ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Supabase ─────────────────────────────────────────────────
# 1. Go to supabase.com → New Project
# 2. Settings → API → copy Project URL and anon/public key
# 3. Rename this file to .env.local and fill in the values
# 4. Run the schema: Supabase Dashboard → SQL Editor → paste supabase/schema.sql → Run
#    (The schema now includes chat_logs and chat_knowledge tables for Ask RI)

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
